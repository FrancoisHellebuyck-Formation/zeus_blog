<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  Anthropic Dark — iTerm2 Color Theme
  Inspiré de l'interface Claude / Anthropic
  Orange corail #D97757 · Fond chaud #1C1814 · Crème #F0E6D3
-->
<dict>

  <!-- Background -->
  <key>Background Color</key>
  <dict>
    <key>Color Space</key><string>sRGB</string>
    <key>Red Component</key>  <real>0.1098</real>
    <key>Green Component</key><real>0.0941</real>
    <key>Blue Component</key> <real>0.0784</real>
    <key>Alpha Component</key><real>1</real>
  </dict>

