<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  Anthropic Light — iTerm2 Color Theme
  Inspiré de l'interface Claude / Anthropic (mode clair)
  Orange corail #D97757 · Fond crème #FDF6EE · Texte sombre #1C1814
-->
<dict>

  <!-- Background (crème chaud Anthropic) -->
  <key>Background Color</key>
  <dict>
    <key>Color Space</key><string>sRGB</string>
    <key>Red Component</key>  <real>0.9922</real>
    <key>Green Component</key><real>0.9647</real>
    <key>Blue Component</key> <real>0.9333</real>
    <key>Alpha Component</key><real>1</real>
  </dict>

  <!-- Foreground (brun sombre chaud) -->
  <key>Foreground Color</key>
  <dict>
    <key>Color Space</key><string>sRGB</string>
    <key>Red Component</key>  <real>0.1490</real>
    <key>Green Component</key><real>0.1176</real>
    <key>Blue Component</key> <real>0.0902</real>
    <key>Alpha Component</key><real>1</real>
  </dict>

  <!-- Cursor (orange Anthropic) -->
