  <dict>
    <key>Color Space</key><string>sRGB</string>
    <key>Red Component</key>  <real>0.8510</real>
    <key>Green Component</key><real>0.4667</real>
    <key>Blue Component</key> <real>0.3412</real>
    <key>Alpha Component</key><real>1</real>
